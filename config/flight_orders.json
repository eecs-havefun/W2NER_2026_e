{
  "dataset": "flight_orders",
  "save_path": "flight_orders_model.pt",
  "predict_path": "flight_orders_output.json",
  "dist_emb_size": 20,
  "type_emb_size": 20,
  "lstm_hid_size": 256,
  "conv_hid_size": 64,
  "bert_hid_size": 768,
  "biaffine_size": 256,

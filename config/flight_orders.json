  "conv_dropout": 0.5,
  "out_dropout": 0.33,
  "epochs": 1,
  "batch_size": 12,
  "learning_rate": 0.001,
  "weight_decay": 0,
  "clip_grad_norm": 5.0,
  "bert_name": "../models/bert_base_chinese",
  "bert_learning_rate": 5e-06,
  "warm_factor": 0.1,
  "use_bert_last_4_layers": true,
  "seed": 123
}